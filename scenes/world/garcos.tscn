[sub_resource type="GDScript" id="GDScript_7n2ot"]
resource_name = "GarcosScript"
script/source = "extends StaticBody2D

@onready var sprite: Sprite2D = $Visual/Sprite2D

var textures: Array = [
	preload(\"res://assets/sprites/Garcos_1.png\"),
	preload(\"res://assets/sprites/Garcos_2.png\")
]

func _ready():
	var index := randi_range(0, textures.size() - 1)
	sprite.texture = textures[index]
"

