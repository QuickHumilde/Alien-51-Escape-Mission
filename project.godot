; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Alien 51: Escape Mission"
run/main_scene="uid://c0wyiru2g8jgf"
config/features=PackedStringArray("4.5", "Forward Plus")
boot_splash/bg_color=Color(0.14117648, 0.1882353, 0.14117648, 1)
boot_splash/image="uid://btog1hgjp6uno"
config/icon="uid://btog1hgjp6uno"

[audio]

buses/default_bus_layout="uid://bvo8tevybdmjq"

[autoload]

Signals="*res://global/signals.gd"
LanguageManager="*res://global/language_manager.gd"
AudioManager="*res://global/audio_manager.gd"
ItemManager="*res://global/item_manager.gd"
MouseController="*res://global/mouse_controller.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
mouse_cursor/custom_image="uid://blt1rsoh1d4w7"

[editor]

run/main_run_args="csc"

[editor_plugins]

enabled=PackedStringArray("res://addons/AutoKey_SpriteFrames/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "green",
"res://assets/": "blue",
"res://global/": "yellow",
"res://scenes/": "purple",
"res://scripts/": "red",
"res://shaders/": "gray",
"res://translations/": "pink"
}

[global_group]

enemy=""
player_ui=""
item=""
obstacle=""
wall=""
player=""
bullet=""
damage=""

